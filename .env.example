# Copy to .env and fill in. SKYRA runs fully offline with NO keys:
# the development AI provider writes a complete plan and the mock image
# engine writes real viewable placeholder images.

# --- Planning (AI Director) ---------------------------------------------
# Which registered AI provider plans the production: "local" (offline) or "openai"
SKYRA_AI_PROVIDER=local
# Model id for the planner (e.g. gpt-4o-mini for openai; "development" offline)
SKYRA_AI_MODEL=development

# --- Image generation ----------------------------------------------------
# Which engine renders scene stills: mock | openai | replicate  (default: mock)
SKYRA_IMAGE_PROVIDER=mock
# Optional model override:
#   openai    -> gpt-image-1 (default)
#   replicate -> black-forest-labs/flux-1.1-pro (default)
# SKYRA_IMAGE_MODEL=

# --- Keys (only for the engine you choose) -------------------------------
# OPENAI_API_KEY=sk-...            # for SKYRA_AI_PROVIDER=openai or SKYRA_IMAGE_PROVIDER=openai
# REPLICATE_API_TOKEN=r8_...       # for SKYRA_IMAGE_PROVIDER=replicate
