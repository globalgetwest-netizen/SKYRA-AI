# Copy to .env and fill in. SKYRA uses REAL AI end to end — there is no mock.
# You need at least a free Gemini key for planning and (ideally) images.

# --- Planning (AI Director) ---------------------------------------------
# Which registered AI provider plans the production (REAL models only):
#   gemini -> Google Gemini (FREE tier)  https://aistudio.google.com/apikey
#   openai -> paid
# If unset, SKYRA auto-picks gemini when GEMINI_API_KEY is present.
SKYRA_AI_PROVIDER=gemini
# Planner model id (e.g. gemini-2.0-flash, gpt-4o-mini)
# SKYRA_AI_MODEL=gemini-2.0-flash

# --- Image generation ----------------------------------------------------
# One engine, OR a comma-separated FALLBACK CHAIN (best first). SKYRA tries
# each in order and falls back to the next if one fails — best quality with
# guaranteed reliability. Engines whose key is missing are skipped. All REAL.
#   pollinations -> FREE, NO KEY needed (great last-resort backup)
#   huggingface  -> FLUX.1-schnell, FREE tier  https://huggingface.co/settings/tokens
#   gemini       -> Google Gemini / Imagen, FREE tier, high quality
#   openai       -> gpt-image-1 (paid)
#   replicate    -> FLUX 1.1 pro, best photoreal (paid)
#
# Recommended quality-first chain:
SKYRA_IMAGE_PROVIDER=gemini,pollinations
#
# Optional per-engine model overrides.
# Gemini image model choices (from best-quality to fastest):
#   imagen-4.0-ultra-generate-001   -> maximum photoreal quality
#   imagen-4.0-generate-001         -> high quality
#   gemini-3-pro-image              -> high quality (Gemini native)
#   gemini-2.5-flash-image          -> fast, free-tier friendly (default)
# SKYRA_GEMINI_MODEL=gemini-2.5-flash-image
# SKYRA_HUGGINGFACE_MODEL=
# SKYRA_POLLINATIONS_MODEL=
# SKYRA_IMAGE_MODEL=            # applies only when a SINGLE engine is set

# --- Video generation (optional) -----------------------------------------
# none      -> skip video, images only (default)
# http      -> FREE: your own/Colab GPU running LTX-Video (see colab/README.md)
# replicate -> paid hosted video (Kling/Wan) via REPLICATE_API_TOKEN
SKYRA_VIDEO_PROVIDER=none
# For http: the public URL of your Colab/local video server (…/generate)
# SKYRA_VIDEO_ENDPOINT=https://xxxx.trycloudflare.com/generate
# For replicate: optional model override
# SKYRA_VIDEO_MODEL=kwaivgi/kling-v1.6-standard

# --- Keys (only for the engine(s) you choose) ----------------------------
# GEMINI_API_KEY=...               # free: planning and/or images
# HUGGINGFACE_API_TOKEN=hf_...     # free: images (FLUX.1-schnell)
# OPENAI_API_KEY=sk-...            # paid: planning and/or images
# REPLICATE_API_TOKEN=r8_...       # paid: images (FLUX 1.1 pro) and video (Kling)
