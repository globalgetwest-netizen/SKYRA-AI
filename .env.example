# Copy to .env and fill in. SKYRA runs fully offline in development mode
# with NO keys — the development AI provider produces a complete plan.

# Which registered AI provider the Director uses: "local" (offline) or "openai"
SKYRA_AI_PROVIDER=local

# Model id passed to the provider (e.g. gpt-4o-mini for openai; "development" offline)
SKYRA_AI_MODEL=development

# Only needed when SKYRA_AI_PROVIDER=openai
# OPENAI_API_KEY=sk-...
