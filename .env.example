# Copy to .env and fill in. SKYRA runs fully offline with NO keys:
# the development AI provider writes a complete plan and the mock image
# engine writes real viewable placeholder images.

# --- Planning (AI Director) ---------------------------------------------
# Which registered AI provider plans the production:
#   local  -> offline, no key
#   gemini -> Google Gemini (FREE tier)  https://aistudio.google.com/apikey
#   openai -> paid
SKYRA_AI_PROVIDER=local
# Planner model id (e.g. gemini-2.0-flash, gpt-4o-mini; "development" offline)
SKYRA_AI_MODEL=development

# --- Image generation ----------------------------------------------------
# One engine, OR a comma-separated FALLBACK CHAIN (best first). SKYRA tries
# each in order and falls back to the next if one fails — best quality with
# guaranteed reliability. Engines whose key is missing are skipped.
#   mock         -> offline placeholder, no key (default)
#   pollinations -> FREE, NO KEY needed (great last-resort backup)
#   huggingface  -> FLUX.1-schnell, FREE tier  https://huggingface.co/settings/tokens
#   gemini       -> Google Gemini image, FREE tier, high quality
#   openai       -> gpt-image-1 (paid)
#   replicate    -> FLUX 1.1 pro, best photoreal (paid)
#
# Recommended quality-first chain:
SKYRA_IMAGE_PROVIDER=gemini,huggingface,pollinations
#
# Optional per-engine model overrides (needed if a default model id is retired):
# SKYRA_GEMINI_MODEL=
# SKYRA_HUGGINGFACE_MODEL=
# SKYRA_POLLINATIONS_MODEL=
# SKYRA_IMAGE_MODEL=            # applies only when a SINGLE engine is set

# --- Keys (only for the engine(s) you choose) ----------------------------
# GEMINI_API_KEY=...               # free: planning and/or images
# HUGGINGFACE_API_TOKEN=hf_...     # free: images (FLUX.1-schnell)
# OPENAI_API_KEY=sk-...            # paid: planning and/or images
# REPLICATE_API_TOKEN=r8_...       # paid: images (FLUX 1.1 pro)
